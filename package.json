{
  "name": "gitspect",
  "version": "0.1.0",
  "description": "Privacy-first, offline-capable Git history analysis tool for AI-assisted developers",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "gitspect": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "git",
    "analytics",
    "cli",
    "developer-tools",
    "insights",
    "git-history",
    "code-analysis",
    "productivity",
    "vibe-coding",
    "retrospective"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/<username>/gitspect.git"
  },
  "bugs": {
    "url": "https://github.com/<username>/gitspect/issues"
  },
  "homepage": "https://github.com/<username>/gitspect#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "simple-git": "^3.24.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
